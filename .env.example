# ─────────────────────────────────────────────
# Son Kaynak — ortam değişkenleri (örnek)
# Bu dosyayı `.env` olarak kopyalayıp değerleri doldur.
# ─────────────────────────────────────────────

# --- Genel ---
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3100
NEXT_PUBLIC_CMS_URL=http://localhost:3101
# Özel yönetim paneli (Payload'ın kendi UI'ı buraya yönlendirilir)
ADMIN_URL=http://localhost:3102
# Payload'ın kendi admin arayüzünü açmak için 'true' yap (varsayılan: kapalı)
ENABLE_PAYLOAD_ADMIN=false

# --- PostgreSQL ---
POSTGRES_USER=sonkaynak
POSTGRES_PASSWORD=sonkaynak_dev_pw
POSTGRES_DB=sonkaynak
# Uygulamaların kullandığı bağlantı (host'tan çalışırken localhost:5433)
DATABASE_URI=postgres://sonkaynak:sonkaynak_dev_pw@localhost:5433/sonkaynak

# --- Payload ---
# 32+ karakter rastgele bir secret üret (örn: openssl rand -hex 32)
PAYLOAD_SECRET=change-me-to-a-long-random-string

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Meilisearch ---
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=meili_dev_master_key

# --- MinIO (S3 uyumlu medya) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=sonkaynak-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
