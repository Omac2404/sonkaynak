# ════════════════════════════════════════════════════════════════
#  SON KAYNAK — Production ortam değişkenleri (EasyPanel)
#  Bu dosyayı kopyalayıp gerçek değerlerle doldurun. Her uygulamanın
#  EasyPanel "Environment" sekmesine ilgili blokları yapıştırın.
#
#  İKİ TÜR URL VAR:
#   • DAHİLİ (internal): EasyPanel servisleri birbirine bu adresle
#     ulaşır. Örn. http://sonkaynak-cms:3101 (servis adı + port).
#   • GENEL (public): Tarayıcının/Google'ın gördüğü gerçek alan adı.
#     NEXT_PUBLIC_* değişkenleri DAİMA genel alan adı olmalı.
# ════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────
#  ORTAK ALTYAPI (EasyPanel servisleri olarak kurun)
# ─────────────────────────────────────────────
# PostgreSQL  → EasyPanel "Postgres" servisi
DATABASE_URI=postgres://KULLANICI:SIFRE@sonkaynak-db:5432/sonkaynak

# Redis       → EasyPanel "Redis" servisi
REDIS_URL=redis://sonkaynak-redis:6379

# Meilisearch → EasyPanel "App" (getmeili/meilisearch:v1.11) servisi
MEILI_HOST=http://sonkaynak-meili:7700
MEILI_MASTER_KEY=DEGISTIRIN_uzun_rastgele_anahtar

# MinIO (S3)  → EasyPanel "App" (minio/minio) servisi veya harici S3
S3_BUCKET=sonkaynak-media
S3_ENDPOINT=https://minio.alanadiniz.com
S3_REGION=us-east-1
S3_ACCESS_KEY=DEGISTIRIN
S3_SECRET_KEY=DEGISTIRIN


# ─────────────────────────────────────────────
#  CMS (apps/cms)  — port 3101
# ─────────────────────────────────────────────
PAYLOAD_SECRET=DEGISTIRIN_uzun_rastgele_32+_karakter
# Public CMS adresi (admin medya, API)
SERVER_URL=https://cms.alanadiniz.com
# CORS/CSRF izinli originler (virgülle): site, admin, cms
CORS_ORIGINS=https://www.alanadiniz.com,https://panel.alanadiniz.com,https://cms.alanadiniz.com
# Custom admin paneli adresi (Payload kendi admin'ine girişi buraya yönlendirir)
ADMIN_URL=https://panel.alanadiniz.com
# İlk admin kullanıcısı (yalnızca DB boşken otomatik oluşturulur)
ADMIN_EMAIL=admin@alanadiniz.com
ADMIN_PASSWORD=DEGISTIRIN_guclu_sifre
# Payload'ın kendi admin arayüzü kapalı kalsın (boş bırakın / false)
# ENABLE_PAYLOAD_ADMIN=false

# CMS'in NEXT_PUBLIC değerleri (build-arg olarak da geçin)
NEXT_PUBLIC_CMS_URL=https://cms.alanadiniz.com
NEXT_PUBLIC_SITE_URL=https://www.alanadiniz.com


# ─────────────────────────────────────────────
#  WEB (apps/web)  — port 3100
# ─────────────────────────────────────────────
# Sunucu tarafı CMS çağrıları DAHİLİ adresten yapılır (hızlı, ağ içi)
CMS_URL=http://sonkaynak-cms:3101
# Tarayıcı/SEO için GENEL adresler (build-arg + runtime)
# NEXT_PUBLIC_SITE_URL=https://www.alanadiniz.com   (yukarıdakiyle aynı)
# NEXT_PUBLIC_CMS_URL=https://cms.alanadiniz.com    (yukarıdakiyle aynı)
# MEILI_HOST / MEILI_MASTER_KEY / REDIS_URL → ortak altyapıdan


# ─────────────────────────────────────────────
#  ADMIN (apps/admin)  — port 3102
# ─────────────────────────────────────────────
# Sunucu tarafı Payload çağrıları DAHİLİ adresten
PAYLOAD_URL=http://sonkaynak-cms:3101
# NEXT_PUBLIC_CMS_URL=https://cms.alanadiniz.com   (medya önizleme, build-arg)
# NEXT_PUBLIC_SITE_URL=https://www.alanadiniz.com  ("Siteyi Gör" linki, build-arg)
